# ==============================================================================
# Yoohoo SaaS — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Generate secrets with: openssl rand -base64 32
# ==============================================================================

# Application
APP_NAME=Yoohoo
APP_ENV=development
DEBUG=true
# REQUIRED: Generate a unique secret key (min 32 chars)
# openssl rand -base64 32
SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-base64-32
API_V1_PREFIX=/api/v1

# Platform Branding
PLATFORM_NAME=Yoohoo
PLATFORM_NAME_SHORT=Yoohoo
PLATFORM_URL=https://yoohoo.nl

# Ports (host-side)
API_PORT=8000
FRONTEND_PORT=1000
NGINX_PORT=80

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=yoohoo
# REQUIRED: Set a strong database password
POSTGRES_PASSWORD=CHANGE-ME-use-a-strong-password
POSTGRES_DB=ps_core_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# JWT
# REQUIRED: Generate a unique JWT secret (min 32 chars)
# openssl rand -base64 32
JWT_SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-base64-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
# Development: localhost ports
# Production: CORS_ORIGINS=https://app.yoohoo.nl
CORS_ORIGINS=http://localhost:3000,http://localhost:1000

# Email (Mailpit in development, real SMTP in production)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yoohoo.nl
SMTP_USE_TLS=false

# Frontend
# Production: FRONTEND_URL=https://app.yoohoo.nl
FRONTEND_URL=http://localhost:2000

# Email verification
EMAIL_VERIFICATION_EXPIRE_HOURS=48
UNVERIFIED_CLEANUP_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# PgBouncer
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432
USE_PGBOUNCER=true

# arq Worker
ARQ_REDIS_DB=1
ARQ_MAX_JOBS=10
ARQ_JOB_TIMEOUT=300

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Sentry Error Tracking
# Create a project at https://sentry.io and paste DSN here
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Frontend Sentry (separate DSN, set as build-time var)
VITE_SENTRY_DSN=

# PostgreSQL App User (privilege separation — runtime access via PgBouncer)
POSTGRES_APP_USER=yoohoo_app
POSTGRES_APP_PASSWORD=CHANGE-ME-use-a-strong-password

# Invitations
INVITATION_EXPIRE_HOURS=72

# Password Reset
PASSWORD_RESET_EXPIRE_MINUTES=30

# 2FA
TOTP_ISSUER_NAME=Yoohoo

# Sessions
MAX_ACTIVE_SESSIONS=10

# Monitoring (Grafana)
# REQUIRED: Change in production
GRAFANA_ADMIN_PASSWORD=changeme

# Backup (optional — offsite rsync target, e.g. user@storage-box:/backups)
BACKUP_REMOTE=

# Docker Image Tag (set by CI/CD, do not set manually in dev)
# IMAGE_TAG=latest
