# ==============================================================================
# Yoohoo SaaS — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# Generate secrets with: openssl rand -base64 32
# ==============================================================================

# Application
APP_NAME=Yoohoo
APP_ENV=development
DEBUG=true
# REQUIRED: Generate a unique secret key (min 32 chars)
# openssl rand -base64 32
SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-base64-32
API_V1_PREFIX=/api/v1

# Platform Branding
PLATFORM_NAME=Yoohoo
PLATFORM_NAME_SHORT=Yoohoo
PLATFORM_URL=https://yoohoo.nl

# Ports (host-side)
API_PORT=8000
FRONTEND_PORT=1000
NGINX_PORT=80

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=yoohoo
# REQUIRED: Set a strong database password
POSTGRES_PASSWORD=CHANGE-ME-use-a-strong-password
POSTGRES_DB=ps_core_db

# PgBouncer (connection pooling)
# DATABASE_URL is used by PgBouncer entrypoint to auto-generate credentials
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# JWT
# REQUIRED: Generate a unique JWT secret (min 32 chars)
# openssl rand -base64 32
JWT_SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-base64-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
# Development: localhost ports
# Production: CORS_ORIGINS=https://app.yoohoo.nl
CORS_ORIGINS=http://localhost:3000,http://localhost:1000

# Email Provider
# Supported: smtp, resend, brevo
EMAIL_PROVIDER=smtp
EMAIL_FROM_NAME=Yoohoo
# Optional fallback provider (used when primary fails/circuit-open)
EMAIL_FALLBACK_PROVIDER=

# SMTP (Mailpit in development, real SMTP in production)
# Production: set SMTP_USE_TLS=true (port 465 = implicit TLS, port 587 = STARTTLS)
# SMTP_USE_TLS=false means NO TLS — only for dev/mailpit
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yoohoo.nl
SMTP_USE_TLS=false

# Resend (https://resend.com — set API key to enable)
RESEND_API_KEY=

# Brevo (https://brevo.com — set API key to enable)
BREVO_API_KEY=

# Email Senders (per-type, optional — falls back to SMTP_FROM / EMAIL_FROM_NAME)
# All sender addresses must be verified in your email provider (Brevo/Resend/SMTP)
EMAIL_ACCOUNT_FROM=account@yoohoo.nl
EMAIL_ACCOUNT_NAME=Yoohoo Account
EMAIL_SECURITY_FROM=security@yoohoo.nl
EMAIL_SECURITY_NAME=Yoohoo Security
EMAIL_NOTIFICATION_FROM=notification@yoohoo.nl
EMAIL_NOTIFICATION_NAME=Yoohoo Notificaties
EMAIL_BILLING_FROM=billing@yoohoo.nl
EMAIL_BILLING_NAME=Yoohoo Billing

# Frontend
# Production: FRONTEND_URL=https://app.yoohoo.nl
FRONTEND_URL=http://localhost:2000

# Email verification
EMAIL_VERIFICATION_EXPIRE_HOURS=48
UNVERIFIED_CLEANUP_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# PgBouncer
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432
USE_PGBOUNCER=true

# arq Worker
ARQ_REDIS_DB=1
ARQ_MAX_JOBS=10
ARQ_JOB_TIMEOUT=300

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Sentry Error Tracking
# Create a project at https://sentry.io and paste DSN here
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Frontend Sentry (separate DSN, set as build-time var)
VITE_SENTRY_DSN=

# PostgreSQL App User (privilege separation — runtime access via PgBouncer)
POSTGRES_APP_USER=yoohoo_app
POSTGRES_APP_PASSWORD=CHANGE-ME-use-a-strong-password

# Invitations
INVITATION_EXPIRE_HOURS=72

# Password Reset
PASSWORD_RESET_EXPIRE_MINUTES=30

# 2FA
TOTP_ISSUER_NAME=Yoohoo

# Sessions
MAX_ACTIVE_SESSIONS=10
SESSION_REMEMBER_ME_DAYS=30
SESSION_DEFAULT_HOURS=8

# Login email verification (magic link)
# When true, non-2FA users must confirm login via email link
# Production: set to true after smoke testing
LOGIN_REQUIRE_EMAIL_VERIFICATION=false
LOGIN_EMAIL_VERIFICATION_EXPIRE_MINUTES=10

# Verification codes (2FA email, recovery)
VERIFICATION_CODE_EXPIRE_MINUTES=10
VERIFICATION_CODE_MAX_ATTEMPTS=5
VERIFICATION_CODE_COOLDOWN_SECONDS=60

# Monitoring (Grafana)
# REQUIRED: Change in production
GRAFANA_ADMIN_PASSWORD=changeme

# Slack Notifications (Alertmanager alerts)
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# Backup (optional — offsite rsync target, e.g. user@storage-box:/backups)
BACKUP_REMOTE=

# Docker Image Tag (set by CI/CD, do not set manually in dev)
# IMAGE_TAG=latest
